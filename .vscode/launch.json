{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug lmms_eval with Accelerate",
            "type": "python",
            "request": "launch",
            "module": "accelerate.commands.launch",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "CUDA_VISIBLE_DEVICES": "0,1,2,3",
                "MODEL_TYPE": "phi3v",
                "MAX_GENERATED_TOKENS": "32",
                "KV_CACHE_TYPE": "tgv_kv",
                "PRUNE_RATIO": "0.9"
            },
            "args": [
                "--num_processes=4",
                "-m",
                "lmms_eval",
                "--model",
                "phi3v",
                "--model_args",
                "model_id_name=microsoft/Phi-3.5-vision-instruct,attn_implementation=eager,device_map=cuda",
                "--tasks",
                "chartqa",
                "--batch_size",
                "1",
                "--log_samples",
                "--output_path",
                "./logs/",
                "--limit",
                "100"
            ]
        }
    ]
}